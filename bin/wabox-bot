#!/usr/bin/env bash
# wabox-bot — bridge wabox (WhatsApp ↔ filesystem) to a pluggable agent backend.
#
#   inbox/<id>.json  →  per-conversation agent session  →  outbox/<id>.json
#
# See README.md for the user-facing description, CONTRIBUTING.md for the
# layout, and docs/backends.md for the backend contract.

set -euo pipefail
shopt -s nullglob

# Resolve the project root from this script's location so we work whether
# wabox-bot is invoked from a clone, a symlink in ~/.local/bin/, or a
# PATH lookup. readlink -f follows symlinks; dirname then strips the
# `bin/` to give us the repo root.
ROOT="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
LIB_DIR="$ROOT/lib"

# Version resolution has no dependencies (no config, no log), so source it up
# front — --version must work before any setup, and the subcommands + daemon
# reuse wabox_bot_version too.
# shellcheck source=lib/version.sh
source "$LIB_DIR/version.sh"

# Self-update lives alongside version resolution: --update / --check-update must
# work before config/log setup, and the daemon + /update slash command reuse the
# same functions. It has no source-time dependencies beyond version.sh (repo/
# branch knobs are read inside the functions), so sourcing it here covers every
# path — the flags below, the `cmd` subcommand's /update, and the daemon.
# shellcheck source=lib/update.sh
source "$LIB_DIR/update.sh"

# --version output: the VERSION file value, plus the short git commit when we're
# running from a checkout (dev builds). git is optional — its absence just drops
# the suffix.
print_version() {
  local v commit
  v="$(wabox_bot_version)"
  if commit="$(git -C "$ROOT" rev-parse --short HEAD 2>/dev/null)"; then
    printf 'wabox-bot %s (%s)\n' "$v" "$commit"
  else
    printf 'wabox-bot %s\n' "$v"
  fi
}

usage() {
  cat <<EOF
Usage: $(basename "$0") [--backend <name>] [--config <path>]
       $(basename "$0") --init-config | --print-config
       $(basename "$0") state --json [--sizes]
       $(basename "$0") transcript <slug> [--limit N]
       $(basename "$0") cmd <slug> "<slash command>"
       $(basename "$0") answer <slug> <yes|no>
       $(basename "$0") send <slug> [text] | send --to <jid> [text]
       $(basename "$0") prompt <slug> <text>
       $(basename "$0") gc [slug] [--yes]
       $(basename "$0") rm <slug> [--yes]
       $(basename "$0") config <list --json | get VAR | set VAR val | unset VAR>

Options:
  --backend <name>    use this backend (overrides WABOX_BOT_BACKEND;
                      default: claude-code). Available backends are .sh
                      files in lib/backends/.
  --config <path>     load this config file (overrides WABOX_BOT_CONFIG;
                      default: \${XDG_CONFIG_HOME:-~/.config}/wabox-bot/config).
  --init-config       write the config template to that path and exit.
  --print-config      print effective config values (secrets masked) and exit.
  --check-update      check whether a newer release is published, then exit
                      (0 up to date, 10 newer available, 1 undetermined).
  --update            update the install to the latest release (git reset --hard
                      to origin/main, as install.sh does), then exit. Prompts for
                      confirmation on a terminal; set WABOX_BOT_ASSUME_YES=1 to skip.
  -v, --version       print the installed version and exit
  -h, --help          show this message and exit

Subcommands (read-only / client verbs — see docs/backends.md):
  state --json [--sizes]
                      print a versioned JSON snapshot of the daemon and every
                      conversation, then exit. --sizes adds per-conversation
                      workdir_bytes / botdir_bytes (opt-in — it runs du).
  transcript <slug> [--limit N]
                      print a versioned JSON transcript (inbound + outbound
                      turns, oldest first) for one conversation, then exit.
  cmd <slug> "<slash command>"
                      run a conversation's slash command (/cwd, /model, /mode,
                      /system, /clear, …) from the CLI, printing its reply
                      instead of sending it over WhatsApp.
  answer <slug> <yes|no>
                      answer a conversation's parked permission request from the
                      CLI, exactly as replying "sim"/"não" over WhatsApp would.
  send <slug> [text|-] [--file <path>...]
  send --to <jid|number> [text|-] [--file <path>...]
                      deliver a message to a conversation (no agent turn). Text
                      omitted or "-" reads stdin. --to targets a raw recipient
                      with no prior conversation. Exit 0 sent, 1 usage.
  prompt <slug> <text|->
                      run an agent turn for a conversation and deliver its reply,
                      suppressing delivery when the reply is empty or the NOOP
                      sentinel (WABOX_PROMPT_NOOP). Exit 0 delivered, 1 usage,
                      3 lock busy, 5 suppressed, 124 backend timeout.
  gc [slug] [--yes]   prune reclaimable bot plumbing (staged media, send
                      archives, aged processed/ envelopes) by mtime. Dry-run
                      unless --yes. No slug ⇒ all conversations. Exit 0, 1 usage.
  rm <slug> [--yes]   delete a conversation completely (session + default
                      workdir). A /cwd override target is preserved. Prompts
                      unless --yes. Exit 0 ok, 1 usage, 3 lock busy.
  config <action> …   read/write the config file. list --json (all vars,
                      secrets masked) · get VAR (raw effective value) · set VAR
                      value · unset VAR (revert to default). Restart the daemon
                      to apply. Exit 0 ok, 1 usage / unknown var.
EOF
}

# A subcommand may be preceded by `--config <path>` / `--config=<path>` to point
# it at an alternate config file (the `config` verb operates on that file; the
# others read it). Strip the flag off the front *only* when a real subcommand
# follows, so `wabox-bot --config X` (daemon mode) is left for the flag parser.
if [[ "${1:-}" == "--config" && $# -ge 3 ]]; then
  case "$3" in
    state | transcript | cmd | answer | send | prompt | gc | rm | config)
      export WABOX_BOT_CONFIG="$2"; shift 2 ;;
  esac
elif [[ "${1:-}" == --config=* ]]; then
  case "${2:-}" in
    state | transcript | cmd | answer | send | prompt | gc | rm | config)
      export WABOX_BOT_CONFIG="${1#--config=}"; shift ;;
  esac
fi

# Positional subcommands (state, transcript, answer) sit beside the flag modes.
# They are clients of a (possibly running) daemon, not a second daemon: they load
# config + backend read-only and never take the single-instance lock. Dispatched
# before the flag parser so `wabox-bot state --json` works with the verb as $1.
# The backend and config come from WABOX_BOT_BACKEND / WABOX_BOT_CONFIG (env or
# the default config file); flags aren't parsed for subcommands.
if [[ "${1:-}" == "state" || "${1:-}" == "transcript" || "${1:-}" == "cmd" \
      || "${1:-}" == "answer" || "${1:-}" == "send" || "${1:-}" == "prompt" \
      || "${1:-}" == "gc" || "${1:-}" == "rm" || "${1:-}" == "config" ]]; then
  SUBCMD="$1"
  shift
  WABOX_BOT_CONFIG="${WABOX_BOT_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/wabox-bot/config}"
  export WABOX_BOT_CONFIG
  # Snapshot the caller's exported environment *before* config.sh applies its
  # defaults, so `config set/unset` can distinguish a real env override from a
  # value that merely came from the file or a built-in default.
  if [[ "$SUBCMD" == "config" ]]; then
    WABOX_CONFIG_PRE_ENV="$(compgen -e 2>/dev/null | tr '\n' ' ' || true)"
  fi
  # shellcheck source=lib/config.sh
  source "$LIB_DIR/config.sh"
  # shellcheck source=lib/log.sh
  source "$LIB_DIR/log.sh"
  # shellcheck source=lib/outbox.sh
  source "$LIB_DIR/outbox.sh"
  # shellcheck source=lib/lastmsg.sh
  source "$LIB_DIR/lastmsg.sh"
  # shellcheck source=lib/workdir.sh
  source "$LIB_DIR/workdir.sh"
  # shellcheck source=lib/backend.sh
  source "$LIB_DIR/backend.sh"
  case "$SUBCMD" in
    state)
      # shellcheck source=lib/state.sh
      source "$LIB_DIR/state.sh"
      state_cli "$@"
      exit $?
      ;;
    transcript)
      # shellcheck source=lib/transcript.sh
      source "$LIB_DIR/transcript.sh"
      transcript_cli "$@"
      exit $?
      ;;
    cmd)
      # handle_slash_command needs only $LOCKS_DIR + write_outbox + the backend
      # hooks + workdir helpers, all sourced above; it takes its own flocks.
      # shellcheck source=lib/commands.sh
      source "$LIB_DIR/commands.sh"
      # shellcheck source=lib/cmd.sh
      source "$LIB_DIR/cmd.sh"
      cmd_main "$@"
      exit $?
      ;;
    answer)
      # shellcheck source=lib/answer.sh
      source "$LIB_DIR/answer.sh"
      answer_main "$@"
      exit $?
      ;;
    send)
      # Dumb delivery: write an outbox job (no backend turn, no lock — the
      # write is atomic). Needs only outbox + lastmsg, both sourced above.
      # shellcheck source=lib/send.sh
      source "$LIB_DIR/send.sh"
      send_main "$@"
      exit $?
      ;;
    prompt)
      # A real agent turn delivered to a conversation. Runs the canonical
      # backend_reply under the per-conversation flock, with the same senddir
      # lifecycle as an inbound turn (so a heartbeat can attach files).
      # shellcheck source=lib/senddir.sh
      source "$LIB_DIR/senddir.sh"
      # shellcheck source=lib/prompt.sh
      source "$LIB_DIR/prompt.sh"
      prompt_main "$@"
      exit $?
      ;;
    gc)
      # Age-based pruning of reclaimable bot plumbing. Read-mostly; takes each
      # conversation's flock non-blocking (workdir/size helpers sourced above).
      # shellcheck source=lib/gc.sh
      source "$LIB_DIR/gc.sh"
      gc_main "$@"
      exit $?
      ;;
    rm)
      # Full conversation deletion. Takes the per-conversation flock; never
      # touches a /cwd override target's contents.
      # shellcheck source=lib/rm.sh
      source "$LIB_DIR/rm.sh"
      rm_main "$@"
      exit $?
      ;;
    config)
      # Structured read/write of the config file (list/get/set/unset). Needs
      # only config.sh (registry + mask helpers), sourced above; no daemon,
      # no lock (whole-file atomic writes).
      # shellcheck source=lib/configverb.sh
      source "$LIB_DIR/configverb.sh"
      configverb_main "$@"
      exit $?
      ;;
  esac
fi

# Argument parsing. Flags win over env vars; both win over built-in defaults.
BACKEND_OVERRIDE=""
CONFIG_OVERRIDE=""
MODE="run"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --backend)
      [[ $# -ge 2 ]] || { printf 'wabox-bot: --backend requires a value\n' >&2; exit 1; }
      BACKEND_OVERRIDE="$2"
      shift 2
      ;;
    --backend=*)
      BACKEND_OVERRIDE="${1#--backend=}"
      shift
      ;;
    --config)
      [[ $# -ge 2 ]] || { printf 'wabox-bot: --config requires a value\n' >&2; exit 1; }
      CONFIG_OVERRIDE="$2"
      shift 2
      ;;
    --config=*)
      CONFIG_OVERRIDE="${1#--config=}"
      shift
      ;;
    --init-config)
      MODE="init-config"
      shift
      ;;
    --print-config)
      MODE="print-config"
      shift
      ;;
    --check-update)
      # No config or dependency setup needed — just git + network. Exits with the
      # update_cli_check contract (0 / 10 / 1) so scripts can branch on it.
      update_cli_check
      exit $?
      ;;
    --update)
      update_cli_apply
      exit $?
      ;;
    -v | --version)
      print_version
      exit 0
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      printf 'wabox-bot: unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

# Resolve the config path (flag > env > XDG default) so every mode agrees.
if [[ -n "$CONFIG_OVERRIDE" ]]; then
  WABOX_BOT_CONFIG="$CONFIG_OVERRIDE"
fi
WABOX_BOT_CONFIG="${WABOX_BOT_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/wabox-bot/config}"
export WABOX_BOT_CONFIG

# --init-config: install the template and exit (needs no libs or dependencies).
if [[ "$MODE" == "init-config" ]]; then
  if [[ -e "$WABOX_BOT_CONFIG" ]]; then
    printf 'wabox-bot: config already exists: %s\n' "$WABOX_BOT_CONFIG" >&2
    printf 'Remove it, or pass --config <path> to write elsewhere.\n' >&2
    exit 1
  fi
  mkdir -p "$(dirname "$WABOX_BOT_CONFIG")"
  cp -- "$ROOT/config.example" "$WABOX_BOT_CONFIG"
  printf 'wrote %s\n' "$WABOX_BOT_CONFIG"
  exit 0
fi

# A config named explicitly with --config must exist (the default path is
# optional and silently ignored when absent).
if [[ -n "$CONFIG_OVERRIDE" && ! -f "$WABOX_BOT_CONFIG" ]]; then
  printf 'wabox-bot: config file not found: %s\n' "$WABOX_BOT_CONFIG" >&2
  exit 1
fi

if [[ -n "$BACKEND_OVERRIDE" ]]; then
  WABOX_BOT_BACKEND="$BACKEND_OVERRIDE"
fi

# Source order matters:
#   - config defines paths used by everyone else
#   - log defines log_* used by check_dependencies + locks + backend
#   - locks reads PID_LOCK + log_error
#   - routing and outbox are self-contained
#   - backend resolves WABOX_BOT_BACKEND, sources lib/backends/<name>.sh,
#     and runs the backend's own dep check
#   - commands depends on backend_* hooks being available
#   - inbox depends on routing, outbox, commands, backend
#   - loop depends on inbox
# shellcheck source=lib/config.sh
source "$LIB_DIR/config.sh"
# shellcheck source=lib/log.sh
source "$LIB_DIR/log.sh"

# --print-config: source the backend (for its defaults) and dump effective
# values, then exit — before the dependency check, lock, and main loop, so it
# works without the runtime binaries installed.
if [[ "$MODE" == "print-config" ]]; then
  # shellcheck source=lib/backend.sh
  source "$LIB_DIR/backend.sh"
  print_config
  exit 0
fi

log_info "wabox-bot $(wabox_bot_version) starting"
check_dependencies
# shellcheck source=lib/locks.sh
source "$LIB_DIR/locks.sh"
acquire_single_instance_lock
install_signal_handlers
# shellcheck source=lib/routing.sh
source "$LIB_DIR/routing.sh"
# shellcheck source=lib/outbox.sh
source "$LIB_DIR/outbox.sh"
# shellcheck source=lib/lastmsg.sh
source "$LIB_DIR/lastmsg.sh"
# shellcheck source=lib/workdir.sh
source "$LIB_DIR/workdir.sh"
# shellcheck source=lib/senddir.sh
source "$LIB_DIR/senddir.sh"
# shellcheck source=lib/media.sh
source "$LIB_DIR/media.sh"
# shellcheck source=lib/backend.sh
source "$LIB_DIR/backend.sh"
run_backend_dependency_check
# shellcheck source=lib/migrate.sh
source "$LIB_DIR/migrate.sh"
run_migrations
# shellcheck source=lib/commands.sh
source "$LIB_DIR/commands.sh"
# shellcheck source=lib/inbox.sh
source "$LIB_DIR/inbox.sh"
# shellcheck source=lib/loop.sh
source "$LIB_DIR/loop.sh"

# Best-effort, backgrounded check for a newer release — logs a notice and caches
# it for /status. Never blocks startup; a no-op when WABOX_BOT_UPDATE_CHECK=0.
update_startup_notice

run_main_loop
